rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - uid: string (required) - The user ID of the owner.
    //   - createdAt: string (required) - When the session was created.
    //   - updatedAt: string (required) - When the session was last updated.
    //   - name: string (required) - The name of the session.
    //   - appState: string (required) - The serialized AppState.
    //
    // Collection: presets
    // Document ID: {presetId}
    // Fields:
    //   - uid: string (required) - The user ID of the owner.
    //   - name: string (required) - The name of the preset.
    //   - instructions: string (required) - The custom AI instructions.
    //   - createdAt: string (required) - When the preset was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidSession() {
      return hasRequiredFields(['uid', 'createdAt', 'updatedAt', 'name', 'appState']) &&
             hasOnlyAllowedFields(['uid', 'createdAt', 'updatedAt', 'name', 'appState']) &&
             request.resource.data.uid is string && request.resource.data.uid.size() > 0 &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string &&
             validStringLength('name', 1, 100) &&
             request.resource.data.appState is string && request.resource.data.appState.size() <= 1000000; // ~1MB limit
    }

    function isValidPreset() {
      return hasRequiredFields(['uid', 'name', 'instructions', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'name', 'instructions', 'createdAt']) &&
             request.resource.data.uid is string && request.resource.data.uid.size() > 0 &&
             validStringLength('name', 1, 100) &&
             request.resource.data.instructions is string && request.resource.data.instructions.size() <= 50000 &&
             request.resource.data.createdAt is string;
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSession() && uidUnchanged();
      allow update: if isDocOwner() && isValidSession() && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /presets/{presetId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPreset() && uidUnchanged();
      allow update: if isDocOwner() && isValidPreset() && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
