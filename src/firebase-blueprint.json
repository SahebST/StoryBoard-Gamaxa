{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "A saved project or session in the app.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the session was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the session was last updated."
        },
        "name": {
          "type": "string",
          "description": "The name of the session."
        },
        "appState": {
          "type": "string",
          "description": "The serialized AppState."
        }
      },
      "required": ["uid", "createdAt", "updatedAt", "name", "appState"]
    },
    "Preset": {
      "title": "Preset",
      "description": "A saved AI instruction preset.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "name": {
          "type": "string",
          "description": "The name of the preset."
        },
        "instructions": {
          "type": "string",
          "description": "The custom AI instructions."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the preset was created."
        }
      },
      "required": ["uid", "name", "instructions", "createdAt"]
    },
    "ModelCache": {
      "title": "ModelCache",
      "description": "Cached AI models for a specific provider.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "providerId": {
          "type": "string",
          "description": "The ID of the provider (e.g., 'openrouter')."
        },
        "models": {
          "type": "string",
          "description": "JSON stringified array of AIModel objects."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the cache was last updated."
        }
      },
      "required": ["uid", "providerId", "models", "updatedAt"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Stores user sessions/projects."
    },
    "/presets/{presetId}": {
      "schema": {
        "$ref": "#/entities/Preset"
      },
      "description": "Stores user AI instruction presets."
    },
    "/modelCache/{cacheId}": {
      "schema": {
        "$ref": "#/entities/ModelCache"
      },
      "description": "Stores cached AI models per provider."
    }
  }
}
